DATABASE_URL="postgresql://user:password@localhost:5432/milanmateria?schema=public"
JWT_SECRET="super-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# MercadoPago — obtenelo en: https://www.mercadopago.com.ar/developers/es/docs/getting-started
MP_ACCESS_TOKEN="TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# URLs — sin trailing slash
# FRONTEND_URL puede ser comma-separated para múltiples orígenes
# Ej: FRONTEND_URL="https://milanmateria.com,https://www.milanmateria.com"
FRONTEND_URL="http://localhost:5174"
BACKEND_URL="http://localhost:3001"

PORT=3001
ADMIN_INITIAL_EMAIL="admin@milanmateria.com"
ADMIN_INITIAL_PASSWORD="Admin123!"

# Email — Nodemailer (cualquier SMTP: Gmail, Brevo, Resend, etc.)
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USER="tu@gmail.com"
MAIL_PASS="app-password-aqui"
MAIL_NOTIFY="admin@milanmateria.com"
